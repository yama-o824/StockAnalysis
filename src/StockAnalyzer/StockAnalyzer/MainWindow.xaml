<Window x:Class="StockAnalyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StockAnalyzer"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
            <Label Content="銘柄：" Width="45"/>
            <TextBox x:Name="SymbolTextBox" TextWrapping="Wrap" Width="165" Height="20"/>
            <Button x:Name="FetchButton" Content="取得" Click="FetchButton_Click" Width="54" Margin="10,0,0,0"/>
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Margin="10,0,0,0"/>
            <ProgressBar x:Name="LoadingBar"
                 Width="120"
                 Height="14"
                 Margin="12,0,0,0"
                 IsIndeterminate="True"
                 Visibility="Collapsed"/>
        </StackPanel>
        <DataGrid Name="PricesDataGrid" Margin="10,10,10,10" AutoGeneratingColumn="PricesDataGrid_AutoGeneratingColumn" />
    </DockPanel>
</Window>
